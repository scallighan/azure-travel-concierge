# Local dev configuration for docker-compose.yml and scripts/run-local.sh.
# Copy to `.env` (compose auto-loads it) and fill in your values.
#
#   cp .env.local.example .env
#
# What must be real (cannot be mocked locally):
#   * Azure AI Foundry endpoint + a chat model deployment (the LLM).
#   * Azure Cosmos DB account with data-plane RBAC for your identity.
# What is mocked automatically: travel-tools search + the whole vic-mock server.

# --- Azure AI Foundry (required) --------------------------------------------
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# --- Azure Cosmos DB (required) ---------------------------------------------
COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
COSMOS_DATABASE=concierge

# --- Optional integrations ---------------------------------------------------
# Azure AI Search for grounded visa guidance (leave blank to skip).
SEARCH_ENDPOINT=
SEARCH_INDEX_NAME=visa-documentation
# Real travel API keys via Key Vault (leave blank for deterministic mock data).
KEY_VAULT_URI=
# Toggle the vic/payment path entirely.
ENABLE_VIC_INTEGRATION=true

# --- Azure auth for CONTAINERS (docker compose only) ------------------------
# The slim Python images have no `az` CLI, so DefaultAzureCredential needs a
# service principal (EnvironmentCredential). Grant it Cosmos Data Contributor +
# Azure AI Foundry user roles. NOT needed for scripts/run-local.sh, which uses
# your host `az login` session.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# --- Web UI ------------------------------------------------------------------
VITE_DEMO_USER_ID=demo-user
