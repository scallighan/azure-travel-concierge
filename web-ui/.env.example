# Agent (Container App) base URL — from `terraform output agent_url`
VITE_AGENT_URL=http://localhost:8080

# Entra SPA app registration — from terraform outputs. Leave blank for mock auth.
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=

# Feature flags
VITE_ENABLE_VIC=true
VITE_MOCK_AUTH=true
VITE_DEMO_USER_ID=demo-user
