# Copy to terraform.tfvars and fill in.
# Never commit real secrets.

subscription_id = "00000000-0000-0000-0000-000000000000"
location        = "EastUS2"
gh_repo         = "your-org/travel-concierge-azure"

# Optional overrides
# chat_model              = "gpt-4o"
# chat_model_version      = "2024-11-20"
# embedding_model         = "text-embedding-3-small"
# enable_vic_integration = true
# container_image_tag     = "latest"

# Reuse an existing Azure AI Search service instead of creating one (saves cost).
# use_existing_search                 = true
# existing_search_service_name        = "my-shared-search"
# existing_search_resource_group_name = "my-shared-rg"   # blank = this deployment's RG
# search_index_name                   = "visa-documentation"

# --- Foundry Toolbox (travel-concierge-toolbox) ------------------------------
# Bundles WebIQ (web intelligence) + the VIC payment tools behind one MCP
# endpoint. The skills and the Foundry-hosted Payments agent consume it.
# foundry_toolbox_name    = "travel-concierge-toolbox"
# foundry_toolbox_version = "13"   # blank = resolve the default version at startup
# payments_agent_name     = "travel-payments-agent"

# --- WebIQ web-intelligence --------------------------------------------------
# The skills connect to WebIQ directly (web/browse/places/...) for richer, more
# current results. Provide the API key (sent as the x-apikey header); it also
# backs the Foundry "webiq" connection. Leave blank to skip WebIQ (falls back to
# the built-in web search).
# webiq_mcp_url = "https://api.microsoft.ai/v3/mcp"
# webiq_api_key = "your-webiq-api-key"


