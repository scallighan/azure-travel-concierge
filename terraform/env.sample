# Terraform provider auth + workflow inputs for the Azure Travel Concierge.
#
# Copy to `.env` (git-ignored) and fill in, then load it before running
# terraform or the deploy scripts:
#
#   cp env.sample .env
#   set -a && source .env && set +a
#   terraform init && terraform apply
#
# ARM_* / AAD auth: for interactive use you can just `az login` and skip the
# service-principal block. Set the ARM_CLIENT_* values for CI / non-interactive
# runs (a service principal with Owner or Contributor + RBAC-admin on the
# subscription). These are consumed by the azurerm and azuread providers.

# --- Azure authentication (service principal; optional if using `az login`) --
export ARM_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
export ARM_TENANT_ID="00000000-0000-0000-0000-000000000000"
export ARM_CLIENT_ID="00000000-0000-0000-0000-000000000000"
export ARM_CLIENT_SECRET="<service-principal-secret>"

# --- Required Terraform inputs (TF_VAR_ overrides *.tfvars) ------------------
# subscription_id is a required variable, distinct from ARM_SUBSCRIPTION_ID.
export TF_VAR_subscription_id="00000000-0000-0000-0000-000000000000"
export TF_VAR_gh_repo="your-org/azure-travel-concierge"
export TF_VAR_location="EastUS2"

# --- Deploy / build scripts (scripts/deploy.sh, scripts/build-images.sh) -----
# GHCR image namespace (owner/name); mirrors TF_VAR_gh_repo.
export GH_REPO="your-org/azure-travel-concierge"
# Image tag pushed to GHCR (defaults to latest).
export TAG="latest"

# --- Optional Terraform input overrides -------------------------------------
# export TF_VAR_chat_model="gpt-5.4"
# export TF_VAR_chat_model_version="2026-03-05"
# export TF_VAR_chat_model_capacity="50"
# export TF_VAR_embedding_model="text-embedding-3-small"
# export TF_VAR_embedding_model_version="1"
# export TF_VAR_container_image_tag="latest"
# export TF_VAR_enable_vic_integration="true"

# Reuse an existing Azure AI Search service instead of creating one (saves cost).
# export TF_VAR_use_existing_search="true"
# export TF_VAR_existing_search_service_name="my-shared-search"
# export TF_VAR_existing_search_resource_group_name="my-shared-rg"
# export TF_VAR_search_index_name="travel-documentation"
